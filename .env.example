# Weights & Biases (wandb) configuration
WANDB_API_KEY=your_wandb_api_key_here
WANDB_PROJECT=parakeet-tdt-basque
WANDB_ENTITY=your_wandb_username_or_team
# Optional: set run name (defaults to auto-generated)
# WANDB_RUN_NAME=parakeet-tdt-basque-v1
# Optional: offline mode (logs locally, sync later with `wandb sync`)
# WANDB_MODE=offline

# HuggingFace token (for dataset download and model upload)
HF_TOKEN=your_huggingface_token_here
